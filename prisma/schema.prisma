generator client {
  provider = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Checkin {
  id         String           @id @default(cuid())
  name       String
  companyId  String           @map("company_id")
  company    Company          @relation(fields: [companyId], references: [id])
  sessions   CheckinSession[]
  activeDays String[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@map("checkins")
}

model CheckinSession {
  id        String   @id @default(cuid())
  checkinId String   @map("checkin_id")
  checkin   Checkin  @relation(fields: [checkinId], references: [id])
  records   Record[] @relation("CheckinRecords")
  createdAt DateTime @default(now())

  @@map("checkin_sessions")
}

model Company {
  id        String    @id @default(cuid())
  name      String
  checkins  Checkin[]
  users     User[]
  ownerId   String?   @unique @map("owner_id")
  owner     User?     @relation("CompanyOwner", fields: [ownerId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("companies")
}

model Record {
  id               String         @id @default(cuid())
  checkinSessionId String         @map("checkin_session_id")
  checkinSession   CheckinSession @relation("CheckinRecords", fields: [checkinSessionId], references: [id])
  userId           String         @map("user_id")
  user             User           @relation("UserRecords", fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@map("records")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  isPasswordSet Boolean   @default(false)
  firstname     String
  lastname      String
  password      String?
  accounts      Account[]
  sessions      Session[]
  companyId     String?   @map("company_id")
  ownedCompany  Company?  @relation("CompanyOwner")
  records       Record[]  @relation("UserRecords")
  isChief       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
